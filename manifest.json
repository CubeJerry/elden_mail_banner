{
  "manifest_version": 3,
  "name": "Elden Email",
  "version": "1.1.2",
  "description": "Shows an Elden Ring banner when you send an email",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "48": "src/assets/icon.png"
    }
  },
  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.cloud.microsoft/*",
    "https://mail.proton.me/*",
    "https://mail.aol.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*",
        "https://mail.proton.me/*",
        "https://mail.aol.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/style.css"],
      "all_frames": true
    }
  ],
  "icons": {
    "48": "src/assets/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/email_sent_yellow.png", 
        "src/assets/email_sent_blue.png", 
        "src/assets/email_sent_red.png",
        "src/assets/elden_ring_sound.mp3", 
        "src/assets/Matinia.otf"
      ],
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*",
        "https://mail.proton.me/*",
        "https://mail.aol.com/*"
      ]
    }
  ]
}
